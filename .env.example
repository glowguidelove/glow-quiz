# Public site URL (used for OG tags, sitemap, share links). Set in Vercel to your production domain.
NEXT_PUBLIC_SITE_URL=https://glowguide.love

# Meta Pixel / Conversions API
# Get these from Meta Business Suite > Events Manager
NEXT_PUBLIC_META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=
# Optional: paste code from Events Manager → Test events → “Confirm your server’s events” (remove after testing)
# META_TEST_EVENT_CODE=

# Kit (ConvertKit) — required for email capture from the quiz
# See docs/kit-email-setup.md (custom fields, tags, Vercel).
# API key: https://app.kit.com/account/edit
# Form ID: Grow → Forms → open form → numeric ID in URL or settings
KIT_API_KEY=
KIT_FORM_ID=
